# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
# For local development: leave as file path
# For production with Turso: libsql://your-db.turso.io
DATABASE_URL=./snippetvault.db
LIBSQL_AUTH_TOKEN=

# Auth (Better Auth)
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@snippetvault.joaovitorps.dev

# Caddy
DOMAIN=localhost
